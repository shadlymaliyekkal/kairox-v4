def fingerprint_waf(headers_str, body_str, cookies_str):
    """Return list of (waf_name, confidence) matches."""
    detected = []
    h = headers_str.lower()
    b = body_str.lower()
    c = cookies_str.lower()
    combined = h + " " + b + " " + c

    for waf, sigs in WAF_SIGNATURES.items():
        score = 0
        for sig in sigs["headers"]:
            if sig.lower() in h: score += 3
        for sig in sigs["body"]:
            if sig.lower() in b: score += 2
        for sig in sigs["cookies"]:
            if sig.lower() in c: score += 2
        if score >= 2:
            conf = "HIGH" if score >= 5 else "MEDIUM" if score >= 3 else "LOW"
            detected.append((waf, conf, score))

    detected.sort(key=lambda x: x[2], reverse=True)
    return detected

