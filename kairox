# ══════════════════════════════════════════════════════════════════
#   SEVERITY CLASSIFICATION
#
#   RULE:
#     HTTP 200 / 301 / 302  on sensitive path  →  HIGH   (actually reachable)
#     HTTP 401              on any path         →  MEDIUM (exists, needs creds)
#     HTTP 403              on any path         →  MEDIUM (firewall blocking — NOT high)
#     URL/subdomain name-only (no status known) →  name-pattern based
#     Ports / services                          →  name-pattern based
# ══════════════════════════════════════════════════════════════════

HIGH_PATHS = [
    r"admin",r"login",r"dashboard",r"panel",r"manager",
    r"api/v\d",r"api/",r"\.env",r"config",r"secret",
    r"token",r"key",r"passwd",r"password",r"backup",
    r"\.git",r"\.svn",r"phpmyadmin",r"wp-admin",r"cpanel",
    r"webmail",r"console",r"swagger",r"graphql",r"actuator",
    r"\.htaccess",r"\.ssh",r"id_rsa",r"shadow",r"passwd",
]
MEDIUM_PATHS = [
    r"ftp",r"smtp",r"8080",r"8443",r"8888",r"proxy",
    r"upload",r"download",r"file",r"static",r"assets",
    r"old",r"bak",r"test",r"dev",r"staging",r"temp",
]

def classify_name(text):
    """Classify by path/name pattern ONLY — no HTTP status involved."""
    t = text.lower()
    for p in HIGH_PATHS:
        if re.search(p, t): return "HIGH"
    for p in MEDIUM_PATHS:
        if re.search(p, t): return "MEDIUM"
    return "LOW"

def classify_path_with_status(url, code):
    """
    Combine path sensitivity with live HTTP status code.

    200 / 301 / 302  →  path is OPEN and reachable  →  honour name-based severity
    401              →  path EXISTS but needs auth   →  MEDIUM (interesting, not free)
    403              →  path is FIREWALL BLOCKED     →  MEDIUM (not freely accessible)
    anything else    →  LOW

    IMPORTANT: 403 is NEVER HIGH — a firewall returning 403 does NOT mean
    the resource is exposed.  It means the opposite.
    """
    c = code.strip()
    if c in ("200", "301", "302"):
        # Truly accessible — name pattern decides severity
        return classify_name(url)
    elif c == "401":
        # Exists but requires credentials
        return "MEDIUM"
    elif c == "403":
        # Firewall / WAF blocking — path may not even exist
        return "MEDIUM"
    else:
        return "LOW"

def status_tag(code):
    return {
        "200": "OPEN",
        "301": "REDIRECT",
        "302": "REDIRECT",
        "401": "AUTH-REQUIRED",
        "403": "FIREWALL/BLOCKED",
    }.get(code.strip(), code.strip())

def sev_col(sev):
    return {"HIGH": RED, "MEDIUM": ORNG, "LOW": GREEN}.get(sev, GREY)

