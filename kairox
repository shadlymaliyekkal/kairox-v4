def run_cmd(cmd,timeout=300):
    try:
        r=subprocess.run(cmd,capture_output=True,text=True,timeout=timeout)
        return True,(r.stdout or "").strip()
    except subprocess.TimeoutExpired: return False,f"[timeout {timeout}s]"
    except FileNotFoundError:         return False,f"[not found: {cmd[0]}]"
    except Exception as e:            return False,f"[error: {e}]"

def lns(raw):
    return [l.strip() for l in raw.splitlines() if l.strip()]

def curl_get(url,extra_args=None,timeout=10):
    """Fetch URL with curl, return (headers_str, body_str, status_code)."""
    cmd=["curl","-s","-L","--max-time",str(timeout),"--connect-timeout","5",
         "-D","-","--insecure","-A","Mozilla/5.0 (compatible; SecurityScanner/1.0)"]
    if extra_args: cmd+=extra_args
    cmd+=[url]
    ok,out=run_cmd(cmd,timeout+5)
    if not ok: return "","","000"
    parts=out.split("\r\n\r\n",1) if "\r\n\r\n" in out else out.split("\n\n",1)
    headers=parts[0] if parts else ""
    body=parts[1][:4000] if len(parts)>1 else ""
    m=re.search(r"HTTP/\S+\s+(\d{3})",headers)
    code=m.group(1) if m else "200"
    return headers, body, code

