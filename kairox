def save_report(recon):
    ts=recon.start_ts.strftime("%Y%m%d_%H%M%S")
    name=f"kairox_{recon.target.replace('.','_')}_{ts}.json"
    dirs_out=[{"path":e,"severity":sev,"status_code":c} for e,sev,c in recon.results["dirs"]]
    data={
        "tool":"KAIROX v4","target":recon.target,"timestamp":recon.start_ts.isoformat(),
        "severity_note":"HIGH=HTTP200/301/302 on sensitive path. MEDIUM=403/401(firewall/auth).",
        "results":{
            "subdomains":recon.results["subdomains"],"live_hosts":recon.results["live_hosts"],
            "urls":recon.results["urls"],"ports":recon.results["ports"],"dirs":dirs_out,
            "waf":recon.results["waf"],"vulns":recon.results["vulns"],
            "ssl":recon.results["ssl"],"dns":recon.results["dns"],
            "tech":recon.results["tech"],"emails":recon.results["emails"],
            "asn":recon.results["asn"],
        },
        "findings":{s:list(i) for s,i in recon.findings.items()},
    }
    try:
        Path(name).write_text(json.dumps(data,indent=2))
        t=Text(); t.append("  ✔  ",style=f"bold {GREEN}")
        t.append("Report saved  →  ",style=f"dim {GREY}"); t.append(name,style=f"bold {C1}")
        console.print(t); console.print()
    except Exception as e:
        console.print(f"  [bold {RED}]⚠[/]  Could not save: {e}\n")

