class KairoxRecon:
    def __init__(self, target):
        self.target   = target.strip().lower().removeprefix("http://").removeprefix("https://").rstrip("/")
        self.results  = {"subdomains":[], "live_hosts":[], "urls":[], "ports":[], "dirs":[]}
        self.findings = {"HIGH":[], "MEDIUM":[], "LOW":[]}
        self.start_ts = datetime.now()

    def _add(self, sev, ftype, value):
        sev = sev if sev in self.findings else "LOW"
        self.findings[sev].append((ftype, value))

    # ── 1. Subdomains ────────────────────────────────────────────
    def run_subdomains(self, prog):
        subs = set()
        if tool_ok("subfinder"):
            prog.log(f"  [bold {C2}]subfinder[/] → passive subdomain scan ...")
            ok, out = run_cmd(["subfinder","-d",self.target,"-all","-recursive","-silent"], 180)
            if ok:
                for s in lns(out): subs.add(s.lower())
        if tool_ok("amass"):
            prog.log(f"  [bold {C2}]amass[/] → OSINT enumeration ...")
            ok, out = run_cmd(["amass","enum","-passive","-d",self.target], 240)
            if ok:
                for s in lns(out): subs.add(s.lower())
        if not tool_ok("subfinder") and not tool_ok("amass"):
            prog.log(f"  [bold {ORNG}]fallback[/] → DNS wordlist probe ...")
            import socket
            wl = ["www","mail","ftp","dev","staging","api","app","test","admin","vpn",
                  "remote","beta","portal","shop","blog","m","mobile","ns1","ns2",
                  "smtp","webmail","cdn","static","assets","media","img","data"]
            for w in wl:
                h = f"{w}.{self.target}"
                try:
                    socket.gethostbyname(h)
                    subs.add(h)
                except: pass
        self.results["subdomains"] = sorted(subs)
        for s in self.results["subdomains"]:
            self._add(classify_name(s), "subdomain", s)

    # ── 2. Live hosts ────────────────────────────────────────────
    def run_live_hosts(self, prog):
        hosts = []
        inputs = self.results["subdomains"] or [self.target]
        if tool_ok("httpx"):
            prog.log(f"  [bold {C2}]httpx[/] → probing live hosts ...")
            try:
                r = subprocess.run(
                    ["httpx","-silent","-status-code","-title","-tech-detect","-server","-no-color"],
                    input="\n".join(inputs), capture_output=True, text=True, timeout=180)
                for line in lns(r.stdout):
                    hosts.append(line)
                    m = re.search(r"\[(\d{3})\]", line)
                    code = m.group(1) if m else "200"
                    self._add(classify_path_with_status(line, code), "live_host", line)
            except Exception as e:
                prog.log(f"  [bold {RED}]httpx error:[/] {e}")
        else:
            prog.log(f"  [bold {ORNG}]fallback[/] → curl HTTP probe ...")
            for h in inputs[:20]:
                for scheme in ("https","http"):
                    url = f"{scheme}://{h}"
                    ok, code = run_cmd(
                        ["curl","-s","-o","/dev/null","-w","%{http_code}",
                         "-L","--max-time","5","--connect-timeout","3",url], 10)
                    if ok and code.strip() in ("200","301","302","403","401"):
                        e = f"{url}  [{code.strip()}  {status_tag(code.strip())}]"
                        hosts.append(e)
                        self._add(classify_path_with_status(url, code), "live_host", e)
                        break
        self.results["live_hosts"] = hosts

    # ── 3. URLs ──────────────────────────────────────────────────
    def run_urls(self, prog):
        urls = set()
        if tool_ok("gau"):
            prog.log(f"  [bold {C2}]gau[/] → harvesting from archives ...")
            ok, out = run_cmd(["gau","--threads","10",self.target], 180)
            if ok:
                for u in lns(out): urls.add(u)
        if tool_ok("waybackurls"):
            prog.log(f"  [bold {C2}]waybackurls[/] → Wayback Machine ...")
            ok, out = run_cmd(["waybackurls",self.target], 120)
            if ok:
                for u in lns(out): urls.add(u)
        # archived URLs have no live status — name-only classification
        for u in list(urls)[:500]:
            self._add(classify_name(u), "url", u)
        self.results["urls"] = sorted(urls)

    # ── 4. Ports ─────────────────────────────────────────────────
    def run_ports(self, prog):
        if tool_ok("nmap"):
            prog.log(f"  [bold {C2}]nmap[/] → scanning common ports ...")
            ports = "21,22,23,25,53,80,110,143,443,445,3306,3389,5432,6379,8080,8443,8888,27017"
            ok, out = run_cmd(["nmap","-sCV","-Pn","-T4","--open","-p",ports,self.target], 300)
            if ok:
                for l in lns(out):
                    if re.search(r"\d+/(tcp|udp)\s+open", l):
                        self.results["ports"].append(l)
                        self._add(classify_name(l), "port", l)
        else:
            prog.log(f"  [bold {ORNG}]fallback[/] → socket port scan ...")
            import socket
            for port in [21,22,23,25,53,80,110,143,443,445,3306,3389,5432,6379,8080,8443]:
                try:
                    s = socket.socket()
                    s.settimeout(1.5)
                    s.connect((self.target, port))
                    s.close()
                    e = f"{port}/tcp  open"
                    self.results["ports"].append(e)
                    self._add(classify_name(e), "port", e)
                except: pass

    # ── 5. Sensitive path detection ──────────────────────────────
    #
    # FIX: severity = classify_path_with_status(url, code)
    #   • 200/301/302 on /admin    → HIGH   (truly open)
    #   • 403         on /admin    → MEDIUM (firewall blocks it — not exposed)
    #   • 401         on /admin    → MEDIUM (exists but needs creds)
    #   • 403         on /backup   → MEDIUM
    #   • 200         on /backup   → HIGH
    #
    def run_dirs(self, prog):
        prog.log(f"  [bold {C2}]path-probe[/] → checking sensitive paths ...")
        paths = [
            "/.env","/.git/HEAD","/.git/config","/robots.txt","/sitemap.xml",
            "/admin","/admin/login","/login","/dashboard","/panel",
            "/wp-admin","/wp-login.php","/phpmyadmin","/cpanel",
            "/api","/api/v1","/api/v2","/graphql","/swagger",
            "/swagger-ui.html","/actuator","/actuator/health",
            "/backup","/backup.zip","/backup.tar.gz",
            "/config.php","/config.yml","/config.json",
            "/.htaccess","/server-status","/server-info",
            "/webmail","/mail","/console","/debug","/test","/trace",
            "/v1/api","/v2/api","/rest/api","/_profiler",
            "/.ssh/id_rsa","/etc/passwd","/proc/self/environ",
        ]
        base_urls = []
        for h in self.results["live_hosts"][:5]:
            m = re.match(r"(https?://[^\s/]+)", h)
            if m: base_urls.append(m.group(1))
        if not base_urls:
            base_urls = [f"https://{self.target}", f"http://{self.target}"]

        for base in base_urls[:3]:
            for path in paths:
                url = base.rstrip("/") + path
                ok, code = run_cmd(
                    ["curl","-s","-o","/dev/null","-w","%{http_code}",
                     "--max-time","5","--connect-timeout","3","-L",url], 10)
                code = code.strip()
                if not ok or code not in ("200","301","302","401","403"):
                    continue

                # ─── STATUS-AWARE CLASSIFICATION ──────────────────────
                # classify_path_with_status() ensures:
                #   403 → always MEDIUM (firewall present, path not exposed)
                #   401 → always MEDIUM (requires credentials)
                #   200/301/302 → HIGH/MEDIUM/LOW based on path name
                # ──────────────────────────────────────────────────────
                sev   = classify_path_with_status(url, code)
                label = status_tag(code)
                entry = f"{url}  [{code}  {label}]"

                # store as tuple (entry_string, severity, code) for grouped display
                self.results["dirs"].append((entry, sev, code))
                self._add(sev, "sensitive_path", entry)

    # ── API endpoint extractor ───────────────────────────────────
    def extract_api_endpoints(self):
        for u in self.results["urls"]:
            if re.search(r"api|graphql|rest|v\d/|\.json|\.xml", u, re.I):
                sev = "HIGH" if classify_name(u) == "HIGH" else "MEDIUM"
                self._add(sev, "api_endpoint", u)

    # ── Master runner ────────────────────────────────────────────
    def run_all(self):
        steps = [
            ("Subdomain Enumeration",    self.run_subdomains, C2,   "◈"),
            ("Live Host Detection",      self.run_live_hosts, GREEN,"◈"),
            ("URL Harvesting",           self.run_urls,       PURP, "◈"),
            ("Port Scanning",            self.run_ports,      ORNG, "◈"),
            ("Sensitive Path Detection", self.run_dirs,       RED,  "◈"),
        ]
        with Progress(
            SpinnerColumn(spinner_name="arc", style=f"bold {C1}"),
            TextColumn(f"[bold {WHITE}]{{task.description}}"),
            BarColumn(bar_width=30, style=C1, complete_style=GREEN, finished_style=GREEN),
            TextColumn(f"[bold {C1}]{{task.percentage:>3.0f}}%"),
            TimeElapsedColumn(),
            console=console, transient=False,
        ) as prog:
            overall = prog.add_task(f"[bold {GOLD}]  ◈  Total Progress[/]", total=len(steps))
            for name, fn, col, icon in steps:
                task = prog.add_task(f"[bold {col}]{icon}[/]  {name}", total=None)
                fn(prog)
                prog.update(task, completed=1, total=1,
                            description=f"[bold {GREEN}]✔[/]  {name}")
                prog.advance(overall)
                time.sleep(0.12)
        self.extract_api_endpoints()

