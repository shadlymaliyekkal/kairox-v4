    console.print(Rule(style=f"bold {TEAL}", characters="━"))
    footer = Text()
    footer.append("  KAIROX v3  ", style=f"bold {C1}")
    footer.append("◈", style=f"bold {GOLD}")
    footer.append("  by Shadly Maliyekkal  ", style=f"bold {PURP}")
