                    self.results["vulns"].append({"sev":sev,"desc":entry,"source":"nikto"})
                    self._add(sev,"nikto-finding",entry)

    # ── 12. HTTP header security audit ──────────────────────────
    def run_header_audit(self,prog):
        prog.log(f"  [bold {C2}]header-audit[/] → checking security headers ...")
        base=f"https://{self.target}"
        headers,body,code=curl_get(base)
        h=headers.lower()

        required={
            "strict-transport-security": ("Missing HSTS Header","MEDIUM","HSTS not set — MITM downgrade possible"),
            "x-frame-options":           ("Missing X-Frame-Options","MEDIUM","Clickjacking protection absent"),
            "x-content-type-options":    ("Missing X-Content-Type-Options","LOW","MIME sniffing not disabled"),
            "content-security-policy":   ("Missing Content-Security-Policy","MEDIUM","No CSP — XSS risk increased"),
            "referrer-policy":           ("Missing Referrer-Policy","LOW","Referrer policy not set"),
            "permissions-policy":        ("Missing Permissions-Policy","LOW","Browser permissions not restricted"),
        }
        for hdr,(name,sev,desc) in required.items():
            if hdr not in h:
                self.results["vulns"].append({"check":name,"sev":sev,"desc":desc,"source":"header-audit"})
                self._add(sev,"header-missing",f"{name}: {desc}")

        dangerous={
            r"server:\s*(\S+)":          ("Server Banner Disclosure","LOW"),
            r"x-powered-by:\s*(.+)":     ("X-Powered-By Disclosure","MEDIUM"),
            r"x-aspnet-version:\s*(.+)": ("ASP.NET Version Disclosed","MEDIUM"),
            r"x-aspnetmvc-version:\s*(.+)":("ASP.NET MVC Version","MEDIUM"),
        }
        for pat,(name,sev) in dangerous.items():
            m=re.search(pat,h)
            if m:
                val=m.group(1).strip()[:80]
                self.results["vulns"].append({"check":name,"sev":sev,"desc":val,"source":"header-audit"})
                self._add(sev,"info-disclosure",f"{name}: {val}")

        # CVE check from banner
        combined=(headers+body).lower()
        for cve,sev,pat,desc in CVE_SIGNATURES:
            if re.search(pat,combined,re.I):
                entry=f"{cve} — {desc} (detected in HTTP response)"
                self.results["vulns"].append({"cve":cve,"sev":sev,"desc":desc,"source":"header-cve"})
                self._add(sev,"cve-http-banner",entry)

    # ── 13. Sensitive path detection ─────────────────────────────
    def run_dirs(self,prog):
        prog.log(f"  [bold {C2}]path-probe[/] → checking sensitive paths ...")
        paths=[
            "/.env","/.git/HEAD","/.git/config","/robots.txt","/sitemap.xml",
            "/admin","/admin/login","/login","/dashboard","/panel",
            "/wp-admin","/wp-login.php","/phpmyadmin","/cpanel",
            "/api","/api/v1","/api/v2","/graphql","/swagger",
            "/swagger-ui.html","/actuator","/actuator/health","/actuator/env",
            "/backup","/backup.zip","/backup.tar.gz","/db.sql","/dump.sql",
            "/config.php","/config.yml","/config.json","/.env.local","/.env.prod",
            "/.htaccess","/server-status","/server-info","/phpinfo.php",
            "/webmail","/mail","/console","/debug","/test","/trace",
            "/v1/api","/v2/api","/rest/api","/_profiler","/telescope","/horizon",
            "/.well-known/security.txt","/.DS_Store","/web.config","/crossdomain.xml",
            "/clientaccesspolicy.xml","/elmah.axd","/trace.axd",
            "/jenkins","/jira","/gitlab","/kibana","/grafana","/prometheus",
        ]
        if tool_ok("ffuf"):
            prog.log(f"  [bold {C2}]ffuf[/] → directory fuzzing ...")
            base_url=f"https://{self.target}/FUZZ"
            wl="/usr/share/wordlists/dirb/common.txt"
            if not os.path.exists(wl): wl="/usr/share/seclists/Discovery/Web-Content/common.txt"
            if os.path.exists(wl):
                ok,out=run_cmd(["ffuf","-u",base_url,"-w",wl,"-mc","200,301,302,401,403",
                                 "-t","20","-timeout","5","-silent"],180)
                if ok:
                    for l in lns(out):
                        m=re.search(r"(\S+)\s+\[Status: (\d+)",l)
                        if m:
                            path_found=m.group(1); code=m.group(2)
                            url=f"https://{self.target}/{path_found}"
                            sev=classify_path_with_status(url,code)
                            entry=f"{url}  [{code}  {status_tag(code)}]"
                            self.results["dirs"].append((entry,sev,code))
                            self._add(sev,"ffuf-path",entry)

        base_urls=[]
        for h in self.results["live_hosts"][:5]:
            mm=re.match(r"(https?://[^\s/]+)",h)
            if mm: base_urls.append(mm.group(1))
        if not base_urls:
            base_urls=[f"https://{self.target}",f"http://{self.target}"]

        for base in base_urls[:3]:
            for path in paths:
                url=base.rstrip("/")+path
                ok,code=run_cmd(["curl","-s","-o","/dev/null","-w","%{http_code}",
                                  "--max-time","5","--connect-timeout","3","-L",
                                  "--insecure",url],10)
                code=code.strip()
                if not ok or code not in ("200","301","302","401","403"): continue
                sev=classify_path_with_status(url,code)
                entry=f"{url}  [{code}  {status_tag(code)}]"
                self.results["dirs"].append((entry,sev,code))
                self._add(sev,"sensitive_path",entry)

    # ── 14. API endpoint extractor ───────────────────────────────
    def extract_api_endpoints(self):
        for u in self.results["urls"]:
            if re.search(r"api|graphql|rest|v\d/|\.json|\.xml",u,re.I):
                sev="HIGH" if classify_name(u)=="HIGH" else "MEDIUM"
                self._add(sev,"api_endpoint",u)

    # ── MASTER RUNNER ────────────────────────────────────────────
    def run_all(self):
        steps=[
            ("Subdomain Enumeration",       self.run_subdomains,    C2,   "◈"),
            ("DNS Records & Zone Transfer",  self.run_dns,           LBLUE,"◈"),
            ("ASN / IP Information",         self.run_asn,           GREY, "◈"),
            ("Live Host Detection",          self.run_live_hosts,    GREEN,"◈"),
            ("Technology Fingerprinting",    self.run_tech,          PURP, "◈"),
            ("WAF / Firewall Detection",     self.run_waf,           GOLD, "◈"),
            ("URL Harvesting",               self.run_urls,          C3,   "◈"),
            ("Port & Service Scanning",      self.run_ports,         ORNG, "◈"),
            ("SSL/TLS Audit",                self.run_ssl,           TEAL, "◈"),
            ("HTTP Security Header Audit",   self.run_header_audit,  PINK, "◈"),
            ("Nuclei Vulnerability Scan",    self.run_nuclei,        RED,  "◈"),
            ("Nikto Web Scan",               self.run_nikto,         RED,  "◈"),
            ("Sensitive Path Detection",     self.run_dirs,          RED,  "◈"),
        ]
        with Progress(
            SpinnerColumn(spinner_name="arc",style=f"bold {C1}"),
            TextColumn(f"[bold {WHITE}]{{task.description}}"),
            BarColumn(bar_width=28,style=C1,complete_style=GREEN,finished_style=GREEN),
            TextColumn(f"[bold {C1}]{{task.percentage:>3.0f}}%"),
            TimeElapsedColumn(),
            console=console,transient=False,
        ) as prog:
            overall=prog.add_task(f"[bold {GOLD}]  ◈  Total Progress[/]",total=len(steps))
            for name,fn,col,icon in steps:
                task=prog.add_task(f"[bold {col}]{icon}[/]  {name}",total=None)
                fn(prog)
                prog.update(task,completed=1,total=1,description=f"[bold {GREEN}]✔[/]  {name}")
                prog.advance(overall); time.sleep(0.10)
        self.extract_api_endpoints()

