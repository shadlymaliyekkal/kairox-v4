                t = Text()
                t.append("    ○  ", style=f"bold {GREEN}")
                t.append(entry, style=GREEN)
                console.print(t)
            console.print()

    # ── API / interesting URLs ──
    interesting = [(tp,v) for sev in ("HIGH","MEDIUM")
                   for tp,v in recon.findings[sev]
                   if tp in ("url","api_endpoint")]
    if interesting:
        section_header("API ENDPOINTS & INTERESTING URLs", PURP)
