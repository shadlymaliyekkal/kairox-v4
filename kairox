def classify_name(text):
    t = text.lower()
    for p in HIGH_PATHS:
        if re.search(p, t): return "HIGH"
    for p in MEDIUM_PATHS:
        if re.search(p, t): return "MEDIUM"
    return "LOW"

def classify_path_with_status(url, code):
    """
    200/301/302 + sensitive path → HIGH (confirmed accessible)
    403         any path         → MEDIUM (firewall — NOT exposed)
    401         any path         → MEDIUM (exists but auth required)
    """
    c = code.strip()
    if c in ("200","301","302"):
        return classify_name(url)
    elif c in ("401","403"):
        return "MEDIUM"
    return "LOW"

def status_tag(code):
    return {"200":"OPEN","301":"REDIRECT","302":"REDIRECT",
            "401":"AUTH-REQUIRED","403":"FIREWALL/BLOCKED"}.get(code.strip(), code.strip())

def sev_col(sev):
    return {"HIGH":RED,"MEDIUM":ORNG,"LOW":GREEN}.get(sev, GREY)

