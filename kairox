        ok,out=run_cmd(["nuclei","-u",base,"-silent","-severity","critical,high,medium",
                        "-tags","cve,exposure,misconfig,default-login,takeover",
                        "-rate-limit","30","-timeout","10"],240)
        if ok:
            for l in lns(out):
                m=re.search(r"\[(critical|high|medium|low|info)\]",l,re.I)
                sev=(m.group(1).upper() if m else "MEDIUM")
                sev="HIGH" if sev=="HIGH" else sev
                entry=l.strip()
                self.results["vulns"].append({"sev":sev,"desc":entry,"source":"nuclei"})
                self._add(sev,"nuclei-finding",entry)

